{
  "name": "codesprint",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "./node_modules/.bin/next dev --turbopack",
    "build": "bun run build:snippets && ./node_modules/.bin/next build",
    "build:snippets": "bun scripts/build-snippets.ts",
    "start": "./node_modules/.bin/next start",
    "lint": "./node_modules/.bin/eslint",
    "test": "./node_modules/.bin/vitest run",
    "test:watch": "./node_modules/.bin/vitest",
    "test:e2e": "./node_modules/.bin/playwright test",
    "sync:leetcode": "bun scripts/sync-leetcode.ts && bun run build:snippets"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/openai": "^3.0.48",
    "@chakra-ui/react": "3.27.1",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@monaco-editor/react": "^4.6.0",
    "ai": "^6.0.141",
    "framer-motion": "12.23.24",
    "monaco-editor": "^0.52.0",
    "monaco-vim": "^0.4.2",
    "next": "15.5.7",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.0.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^27.4.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
